{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(assets/.*|canvaskit/.*|icons/.*|favicon.png|flutter.js|flutter_bootstrap.js|flutter_service_worker.js|main.dart.js|manifest.json|version.json)",
      "destination": "/build/web/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/build/web/index.html"
    }
  ]
}
